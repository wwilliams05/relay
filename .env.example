# Apollo (people search + email enrichment)
APOLLO_API_KEY=
# live | fixture | auto  (auto = live if APOLLO_API_KEY is set, else fixture)
RELAY_APOLLO_MODE=auto

# Job discovery. ats = official ATS APIs only (targets.yml) | live = JobSpy board
# scraping only | fixture = offline sample jobs | auto = ATS + JobSpy merged, falling
# back to JobSpy then fixtures only if ATS is empty (auto never stalls on scraping)
RELAY_JOBS_MODE=auto
RELAY_JOBS_LOCATION=United States
RELAY_JOBS_RESULTS=20
# Drop discovered jobs scoring below this (0-100) so the Jobs tab stays on-target and
# doesn't fill with the engineering roles the target companies also post. 0 = keep all.
RELAY_JOBS_MIN_FIT=20
# ATS APIs (Greenhouse/Lever/Ashby) — reliable, no-auth job discovery. 1 = on (default).
RELAY_ATS=1
# Company list for ATS discovery (relative paths resolve from the repo root)
RELAY_ATS_TARGETS=targets.yml

# Tracker backend: xlsx (default, no credentials) | sheets
RELAY_TRACKER_BACKEND=xlsx
# Local .xlsx tracker path (relative paths resolve from the repo root)
RELAY_WORKBOOK_PATH=relay.xlsx
# Where the parsed resume Profile is cached
RELAY_PROFILE_PATH=profile.json

# Google Sheets tracker (only needed when RELAY_TRACKER_BACKEND=sheets)
SHEETS_WORKBOOK_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# Gmail drafts (compose-only OAuth — Relay creates drafts, never sends)
# live = real Gmail drafts | fixture = local .eml files in RELAY_DRAFTS_DIR |
# auto = live if the OAuth client/token below exists, else fixture
RELAY_GMAIL_MODE=auto
GMAIL_OAUTH_CLIENT=./gmail_client.json
GMAIL_TOKEN_PATH=./gmail.token.json
RELAY_DRAFTS_DIR=drafts

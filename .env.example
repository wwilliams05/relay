# Apollo (people search + email enrichment)
APOLLO_API_KEY=
# live | fixture | auto  (auto = live if APOLLO_API_KEY is set, else fixture)
RELAY_APOLLO_MODE=auto

# Tracker backend: xlsx (default, no credentials) | sheets
RELAY_TRACKER_BACKEND=xlsx
# Local .xlsx tracker path (relative paths resolve from the repo root)
RELAY_WORKBOOK_PATH=relay.xlsx

# Google Sheets tracker (only needed when RELAY_TRACKER_BACKEND=sheets)
SHEETS_WORKBOOK_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# Gmail drafts (compose-only OAuth)
GMAIL_OAUTH_CLIENT=./gmail_client.json
